(*maximum d'une liste v2*)
let rec max_list = function 
  |[] -> failwith "vide"
  |[a] -> a
  |a::q -> max a (max_list q);;

max_list [6; 1; 9];;

(*longueur d'une liste*)
let rec longueur = function 
  |[] -> 0 
  |a::q -> 1 + (longueur q);;

longueur [6; 8; 1];;

(*maximum de deux listes*)
let rec max_liste u v = match (u, v) with
  |([] , v) -> v 
  | (u , []) -> u 
  |(a::q, b::s) -> (max a b)::max_liste q s;;

max_liste [6; 1; 9; 8; 10] [7; 10; 2; 4];; 

(*test d'appartenance*)
let rec appartient x l = match l with 
  |[] -> false
  |a::q when a = x -> true
  |a::q -> appartient x q;;

appartient 7 [7; 6; 1; 0];; 

(*nombre d'éléments pairs dans une liste*)
let rec nb_pairs liste = match liste with 
  |[] -> 0 
  |a::q when a mod 2 = 0 -> 1 + nb_pairs q 
  |a::q -> nb_pairs q;;

nb_pairs [6; 8; 7; 4];;

(*signe d'un entier*)
let signe n = 
  if n > 0 then 1 
  else if n < 0 then -1 
  else 0;;

signe 0;;

(*manipulation de types basiques*) 

(*signe d'un produit*) 
type signe = Positif | Negatif;; 

let signe_produit x y = match x, y with 
  |Positif , Negatif | Negatif, Positif -> Negatif
  |Negatif, Negatif -> Positif 
  |Positif, Positif -> Positif;;

(*fonction et*)
type bool = Vrai | Faux;; 

let et (a : bool) (b : bool) = match a,b with 
  |_, Faux | Faux, _ -> Faux 
  |Vrai, Vrai -> Vrai;;

(*type complexe et fonctions conjugué et norme*)

type complexe = {re : float; im : float};;

let conjugue (x : complexe) = {re = x.re; im = -.x.im};;


conjugue {re = -1.; im = 7.};;


let norme (z : complexe) = match z with 
  |{re = x; im = y} -> sqrt( x ** 2. +. y ** 2.);;

norme {re = -2.; im = 7.};;

