(*puissance recursive*)
let rec puissance x n=
  if n = 0 then 1. 
  else x *. (puissance x (n-1));;

puissance 3. 2;;

(*composition de fonctions*)
let compose f g x = f (g x);;

let x = 3 in
let f x = x + 1 in
let g x = 2 * x in 
compose f g x;;

