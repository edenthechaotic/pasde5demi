(*factorielle*)
let fact n  = 
   let rep = ref 1 in 
   for i = 1 to n do
     rep := !rep * i
   done ;
   !rep;;

 fact 5;;


(*somme d'éléments d'une liste*)
let rec somme liste = match liste with 
   |[] -> 0
   |a::q -> a + somme q;;

 somme [5; 9; 1];;
    
(*maximum d'une liste*)
 let rec max_liste liste = match liste with 
   |[] -> failwith "liste vide"
   |[a] -> a 
   |a::q -> max a (max_liste q);;

 max_liste [5; 9; 1];;

