(*deux manières d'incrémenter un compteur*)

type compteur = { debut : int; fin : int; mutable counte : int};;  

let incremente (c : compteur) = 
       if c.counte < c.fin then c.counte <- c.counte + 1
       else failwith "compteur trop grand";; 

let a = { debut = 0; fin = 5; counte = 3};;

incremente a;; 

print_int a.counte;; 

