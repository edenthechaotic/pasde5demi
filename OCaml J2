(*on cherche le premier entier k tq k! > n*)

let inverse_fact (n : int) = 
        let k = ref 0 in 
        let f = ref 1 in 
        while !f < n do 
                k := !k +1; f := !f * !k 
        done;
        print_int !k; 
        print_endline "\n";
        !k;; 

