(*algorithme de Dijkstra on suppose une file de priorité déjà implémentée*)

let dijkstra (g : wgraphe) (s : int) = 
  let dist = Array.make (w_size g) infinity in 
  let q = Pqueue.create () in 
  let visited = Array.make (w_size g) false in
  let add d v = dist.(v) <- d; Pqueue.push (d, v) q in 
  add 0. s; 
  while not (Pqueue.is_empty q) do 
    let dv, v = Pqueue.pop q in 
    if not (visited.(v)) then 
      (
        visited.(v) <- true; 
        List.iter (fun (w, dvw) -> let d = dv +. dvw in 
                    if d < dist.(w) then add d w) (succ g v)
      )
  done; 
  dist;;
